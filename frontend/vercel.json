{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://<YOUR_BACKEND_URL>/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://<YOUR_BACKEND_URL>/socket.io/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://<YOUR_BACKEND_URL>/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
